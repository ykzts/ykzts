{
  "author": "Yamagishi Kazutoshi",
  "dependencies": {
    "@ykzts/site-config": "workspace:*",
    "@ykzts/utils": "workspace:*",
    "@portabletext/types": "4.0.2",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "next": "catalog:",
    "zod": "4.4.3"
  },
  "description": "Supabase database type definitions for ykzts applications",
  "devDependencies": {
    "@types/node": "catalog:",
    "@ykzts/tsconfig": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./src/types.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./image-upload": {
      "types": "./src/image-upload.ts",
      "default": "./src/image-upload.ts"
    },
    "./image-validation": {
      "types": "./src/image-validation.ts",
      "default": "./src/image-validation.ts"
    },
    "./dto": {
      "types": "./src/dto.ts",
      "default": "./src/dto.ts"
    },
    "./next-image-config": {
      "types": "./src/next-image-config.ts",
      "default": "./src/next-image-config.ts"
    },
    "./queries": {
      "types": "./src/queries.ts",
      "default": "./src/queries.ts"
    },
    "./revalidate": {
      "types": "./src/revalidate.ts",
      "default": "./src/revalidate.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./src/auth.ts"
    },
    "./blog-urls": {
      "types": "./src/blog-urls.ts",
      "default": "./src/blog-urls.ts"
    },
    "./proxy": {
      "types": "./src/proxy.ts",
      "default": "./src/proxy.ts"
    },
    "./service-role": {
      "types": "./src/service-role.ts",
      "default": "./src/service-role.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "license": "MIT",
  "name": "@ykzts/supabase",
  "private": true,
  "repository": {
    "directory": "packages/supabase",
    "type": "git",
    "url": "https://github.com/ykzts/ykzts.git"
  },
  "scripts": {
    "test": "vitest --run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typegen": "./scripts/typegen.sh"
  },
  "type": "module",
  "types": "./src/types.ts",
  "version": "1.0.0"
}
